{
    "MinLevel": 1, //[Level Requirement] Minimum player level required to access Tony LL1.
    "UnlockedByDefault": false, //[Unlock] If true, Tony is unlocked immediately regardless of level.

    "TraderRefreshMin": 1800, //[Restock Timer] Minimum refresh time in seconds. 1800 = 30 min.
    "TraderRefreshMax": 3600, //[Restock Timer] Maximum refresh time in seconds. 3600 = 60 min.
    "RerollAssortOnRestock": true, //[Restock] If true, Tony rerolls cash/barter split and stock on restock.

    "AddTraderToFleaMarket": true, //[Flea] If true, Tony's offers appear in flea search.
    "EnableCustomQuests": true, //[Quests] If false, Tony main quests and quest zones do not load.
    "EnableCustomSideQuests": true, //[Quests] If false, Tony side quests do not load.

    "InsurancePriceCoef": 45, //[Insurance] Insurance price coefficient. Higher is more expensive.
    "RepairQuality": 0.9, //[Repair] Repair quality. 0.0 to 1.0.

    "RandomizeStockAvailable": true, //[Stock] If true, some eligible offers become out of stock each reset.
    "OutOfStockChance": 5, //[Stock] Percent of eligible offers that can become out of stock.
    "PreventBarterOffersOutOfStock": true, //[Stock] If true, barter offers cannot be randomly zeroed.
    "UnlimitedStock": false, //[Stock] If true, all offers become unlimited stock.

    "PriceMultiplier": 1.0927, //[Pricing] Global multiplier for all money prices.
    "CashOffersOnly": false, //[Pricing] If true, Tony only uses cash offers.
    "RandomizeCashBarterOffers": true, //[Pricing] If true, eligible offers can roll cash or barter.
    "CashOfferPercent": 85, //[Pricing] Percent of configured offers that should stay cash.
    "ManualBarters": false, //[Barter] If false, Tony can auto-generate barter recipes. Advanced options are in config/generated_trade_settings.jsonc.

    "DebugLogging": false, //[Debug] Enables detailed logs.
    "RealDebugLogging": false //[Debug] Enables very detailed logs.
}
