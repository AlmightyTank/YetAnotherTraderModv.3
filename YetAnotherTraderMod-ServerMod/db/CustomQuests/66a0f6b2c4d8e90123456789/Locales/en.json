{
    // Quest 2
    "6a300025d2999bc7b9bba916 name": "Back Room Etiquette",
    "6a300025d2999bc7b9bba916 description": "Concordia had security before it had ghosts. Cameras, guards, records, keys, people who looked the other way when paid. One of my old ledgers used to sit in that security room, until someone smart moved it before the wrong eyes found it. Now it is stashed in a maintenance closet under the ramp on Ground Zero. Find it, recover it, and leave alive. Do not make a scene.",
    "6a300025d2999bc7b9bba916 note": "Tony wants you to recover an old security ledger hidden in a maintenance closet under the ramp on Ground Zero.",
    "6a300025d2999bc7b9bba916 startedMessageText": "Ground Zero. Maintenance closet under the ramp. My ledger is there now. Bring it back clean.",
    "6a300025d2999bc7b9bba916 successMessageText": "Good. That ledger in the wrong hands would have made problems. You followed instructions and kept your head down. That matters.",
    "6a300025d2999bc7b9bba916 failMessageText": "You either lost the trail or made too much noise following it.",
    "6a300025d2999bc7b9bba916 acceptPlayerMessage": "I'll get the ledger.",
    "6a300025d2999bc7b9bba916 declinePlayerMessage": "Not going into Ground Zero for that yet.",
    "6a300025d2999bc7b9bba916 completePlayerMessage": "Here's your ledger.",
    "6a300025d2999bc7b9bba916 changeQuestMessageText": "Tony wants the relocated ledger recovered quietly from Ground Zero.",

    "6a300025d2999bc7b9bba917": "Locate the maintenance closet under the ramp on Ground Zero",
    "6a300025d2999bc7b9bba918": "Find Tony's security ledger",
    "6a300025d2999bc7b9bba919": "Survive and extract from Ground Zero",
    "6a300025d2999bc7b9bba91a": "Hand over Tony's security ledger",

    // Quest 3
    "6a300025d2999bc7b9bba91b name": "First Dead Drop",
    "6a300025d2999bc7b9bba91b description": "The Concordia ledger you recovered still has a useful name in it. One of my people left a sealed envelope in the Factory office building, second-floor locker room. You will move it to Ground Zero. Underground level, meat truck, far back. The man collecting it works for Prapor. He must not know where it came from or who carried it. Do not open it. Do not lose it. Do not bring it back to me.",
    "6a300025d2999bc7b9bba91b note": "Move Tony's sealed envelope from the second-floor Factory office locker room to the far back of the underground meat truck on Ground Zero.",
    "6a300025d2999bc7b9bba91b startedMessageText": "Factory office, second-floor locker room. Get the envelope. Then Ground Zero, underground meat truck, far back. Leave it there and walk away.",
    "6a300025d2999bc7b9bba91b successMessageText": "Good. The envelope is where it needs to be. Prapor's man will remember what he owes and who still has the paper to prove it.",
    "6a300025d2999bc7b9bba91b failMessageText": "You lost the envelope, lost the route, or lost your nerve.",
    "6a300025d2999bc7b9bba91b acceptPlayerMessage": "I'll move the envelope.",
    "6a300025d2999bc7b9bba91b declinePlayerMessage": "I'm not running dead drops.",
    "6a300025d2999bc7b9bba91b completePlayerMessage": "The envelope is planted.",
    "6a300025d2999bc7b9bba91b changeQuestMessageText": "Tony wants the sealed envelope moved through an old courier route.",

    "6a300025d2999bc7b9bba91c": "Locate the sealed envelope in the Factory office locker room",
    "6a300025d2999bc7b9bba91d": "Obtain Tony's sealed envelope",
    "6a300025d2999bc7b9bba91e": "Survive and extract from Factory",
    "6a300025d2999bc7b9bba91f": "Stash Tony's sealed envelope in the Ground Zero meat truck",
    "6a300025d2999bc7b9bba920": "Survive and extract from Ground Zero",

    // Prapor's side quest 1 - Army Leftovers
    "6a300025d2999bc7b9bba921 name": "Army Leftovers",
    "6a300025d2999bc7b9bba921 description": "That envelope reached the right hands. Funny thing about frightened men, they remember things. One of Prapor's people just remembered an old Reserve parts cache that never made it onto the books. Locked away behind RB-ST, where most rats stop looking. AK furniture, worn spares, magazines, cheap army scraps. I do not need you dragging metal across the base. Get inside, find the cache, mark it, and leave. My people will collect what Prapor forgot.",
    "6a300025d2999bc7b9bba921 note": "Tony wants you to access RB-ST on Reserve and mark a forgotten army parts cache so his people can recover it later.",
    "6a300025d2999bc7b9bba921 startedMessageText": "Go to Reserve. Get into RB-ST, find the old army parts cache, and mark it. Do not get greedy. Do not start opening crates.",
    "6a300025d2999bc7b9bba921 successMessageText": "Good. The cache is marked. Prapor's man gave us the memory, you got through the lock, and now the leftovers belong to me.",
    "6a300025d2999bc7b9bba921 failMessageText": "You either never got through RB-ST, missed the cache, or made too much noise near it. That is how useful things disappear.",
    "6a300025d2999bc7b9bba921 acceptPlayerMessage": "I'll get into RB-ST and mark the cache.",
    "6a300025d2999bc7b9bba921 declinePlayerMessage": "Not touching Prapor's locked leftovers yet.",
    "6a300025d2999bc7b9bba921 completePlayerMessage": "The RB-ST cache is marked.",
    "6a300025d2999bc7b9bba921 changeQuestMessageText": "Tony wants the RB-ST cache marked, not looted.",

    "6a300025d2999bc7b9bba922": "Forgotten army parts cache",
    "6a300025d2999bc7b9bba923": "Locate the forgotten army parts cache behind RB-ST on Reserve",
    "6a300025d2999bc7b9bba924": "Mark the army parts cache for Tony",
    "6a300025d2999bc7b9bba925": "Survive and extract from Reserve",

    // Quest 4
    "6a300025d2999bc7b9bba926 name": "No Names Spoken",
    "6a300025d2999bc7b9bba926 description": "Names are dangerous. Symbols last longer. Take my card to Factory and leave it in the third-floor office, on the desk where people will see it. No signatures, no speeches, no bodies in Scav jackets. Fence opened the first door for you, and I do not repay useful men with dead workers. Plant the card, leave alive, and say nothing.",
    "6a300025d2999bc7b9bba926 note": "Tony wants you to plant his calling card on the third-floor office desk in Factory without killing Scavs.",
    "6a300025d2999bc7b9bba926 startedMessageText": "Factory. Third-floor office. Put the card on the desk. Do not kill Scavs.",
    "6a300025d2999bc7b9bba926 successMessageText": "Good. The card is on the desk, and the Scavs are still breathing. The right people will see the mark and understand without hearing my name.",
    "6a300025d2999bc7b9bba926 failMessageText": "You made noise where I asked for silence. A dead Scav carries the wrong message.",
    "6a300025d2999bc7b9bba926 acceptPlayerMessage": "I'll plant the card.",
    "6a300025d2999bc7b9bba926 declinePlayerMessage": "Not going quiet into Factory yet.",
    "6a300025d2999bc7b9bba926 completePlayerMessage": "The card is planted.",
    "6a300025d2999bc7b9bba926 changeQuestMessageText": "Tony wants his calling card planted on the Factory third-floor office desk without Scav blood on it.",

    "6a3007dfd2999bc7b9bba9b3": "Locate the Third-Floor Office in Factory",
    "6a300025d2999bc7b9bba927": "Plant Tony's calling card on the third-floor office desk in Factory",
    "6a300025d2999bc7b9bba928": "Survive and extract from Factory",
    "6a300025d2999bc7b9bba929": "Do not kill any Scavs on Factory",

    // Quest 5
    "6a30a341d2999bc7b9bbaa32 name": "Street Tax",
    "6a30a341d2999bc7b9bbaa32 description": "The card was seen. Now comes the bill. Customs has roads for men who do not like checkpoints, offices for goods with no paperwork, dorm rooms where cash changes hands, and gas stations where deals get settled behind locked doors. Big Red keeps the paper. Three-story Dorms keeps the dirty money. New Gas keeps the route moving. Hit all three points, make sure the route is still open, then bring me my cut in cash and gold. I do not care where you lift it from, as long as it comes back clean. You keep the collector's fee.",
    "6a30a341d2999bc7b9bbaa32 note": "Tony wants you to check the Customs collection route at Big Red, three-story Dorms, and New Gas, then bring him his cut.",
    "6a30a341d2999bc7b9bbaa32 startedMessageText": "Customs. Big Red upstairs office, three-story Dorms near marked room, then New Gas office. Check the route, collect enough cash and gold, and come back alive.",
    "6a30a341d2999bc7b9bbaa32 successMessageText": "Good. Big Red, Dorms, New Gas, cash, gold. The route is still open, and the bill got paid. Keep your collector's fee. You earned that much.",
    "6a30a341d2999bc7b9bbaa32 failMessageText": "You lost the route, lost the money, or forgot whose tax you were collecting.",
    "6a30a341d2999bc7b9bbaa32 acceptPlayerMessage": "I'll collect the tax.",
    "6a30a341d2999bc7b9bbaa32 declinePlayerMessage": "Not collecting from Customs yet.",
    "6a30a341d2999bc7b9bbaa32 completePlayerMessage": "Here's your cut.",
    "6a30a341d2999bc7b9bbaa32 changeQuestMessageText": "Tony wants the Customs route checked and his cut brought back in cash and gold.",

    "6a30a341d2999bc7b9bbaa33": "Locate the upstairs Big Red office collection point",
    "6a30a341d2999bc7b9bbaa34": "Locate the three-story Dorms marked room collection point",
    "6a30a341d2999bc7b9bbaa35": "Locate the New Gas office collection point",
    "6a30a341d2999bc7b9bbaa36": "Find 60,000 RUB in raid",
    "6a30a341d2999bc7b9bbaa37": "Find 1 golden rooster in raid",
    "6a30a341d2999bc7b9bbaa38": "Find 2 gold chains in raid",
    "6a30a341d2999bc7b9bbaa39": "Survive and extract from Customs",
    "6a30a341d2999bc7b9bbaa3a": "Hand over 30,000 RUB",
    "6a30a341d2999bc7b9bbaa3b": "Hand over 1 golden rooster",
    "6a30a341d2999bc7b9bbaa3c": "Hand over 1 gold chain",

    // Quest 6
    "6a30b2fbd2999bc7b9bbaa96 name": "Old BEAR Trails",
    "6a30b2fbd2999bc7b9bbaa96 description": "The Customs route pays again. Good. But money is useless if every road is watched. Before Tarkov broke open, BEAR teams used paths through Woods that never touched the main roads. Old Station, Scav bunker, Abandoned Village. Those routes were quiet once. I want to know if they still are. Mark them, leave alive, and do not waste time looking for souvenirs. I am not sending you for supplies. I am seeing if you can follow ghosts.",
    "6a30b2fbd2999bc7b9bbaa96 note": "Tony wants you to mark three old BEAR route points on Woods and survive.",
    "6a30b2fbd2999bc7b9bbaa96 startedMessageText": "Woods. Old Station, Scav bunker, Abandoned Village. Mark the old BEAR routes and leave alive.",
    "6a30b2fbd2999bc7b9bbaa96 successMessageText": "Good. The old marks have new teeth. Those trails can still be walked, and now I know you can walk them.",
    "6a30b2fbd2999bc7b9bbaa96 failMessageText": "You lost the trail. That is how men disappear in Woods.",
    "6a30b2fbd2999bc7b9bbaa96 acceptPlayerMessage": "I'll mark the routes.",
    "6a30b2fbd2999bc7b9bbaa96 declinePlayerMessage": "Not walking old BEAR trails yet.",
    "6a30b2fbd2999bc7b9bbaa96 completePlayerMessage": "The routes are marked.",
    "6a30b2fbd2999bc7b9bbaa96 changeQuestMessageText": "Tony wants the old BEAR routes marked on Woods.",

    "6a30b2fbd2999bc7b9bbaa97": "Mark the old BEAR route near Old Station",
    "6a30b2fbd2999bc7b9bbaa98": "Mark the old BEAR route near Scav bunker",
    "6a30b2fbd2999bc7b9bbaa99": "Mark the old BEAR route near Abandoned Village",
    "6a30b2fbd2999bc7b9bbaa9a": "Survive and extract from Woods",

    // Quest 7
    "6a30b2fbd2999bc7b9bbaab5 name": "Buried Steel",
    "6a30b2fbd2999bc7b9bbaab5 description": "The old trails are open. That means people can move again. One of mine already did his part and left two sealed military weapon crates in the E2 bunkers on Reserve. He does not know your name, and you do not know his. That is how this works. Find the buried cache, recover both crates, and bring them to me sealed. If the wire is cut or one crate is missing, do not bother making excuses.",
    "6a30b2fbd2999bc7b9bbaab5 note": "Tony wants you to recover two sealed military weapon crates from the E2 bunkers on Reserve.",
    "6a30b2fbd2999bc7b9bbaab5 startedMessageText": "Reserve. E2 bunkers. Two sealed crates were left for us. Recover them and leave alive.",
    "6a30b2fbd2999bc7b9bbaab5 successMessageText": "Good. Both crates are sealed. That means my people can move product, and you can carry it without asking questions. I pulled a little loose steel from another box for you. Do not mistake it for generosity.",
    "6a30b2fbd2999bc7b9bbaab5 failMessageText": "A missing crate, a broken seal, or a dead courier. None of those help me.",
    "6a30b2fbd2999bc7b9bbaab5 acceptPlayerMessage": "I'll recover the crates.",
    "6a30b2fbd2999bc7b9bbaab5 declinePlayerMessage": "Not going into E2 for crates yet.",
    "6a30b2fbd2999bc7b9bbaab5 completePlayerMessage": "The crates are here.",
    "6a30b2fbd2999bc7b9bbaab5 changeQuestMessageText": "Tony wants both sealed crates recovered from the Reserve E2 bunkers.",

    "6a30b2fbd2999bc7b9bbaab6": "Locate the buried weapons cache in the Reserve E2 bunkers",
    "6a30b2fbd2999bc7b9bbaab7": "Recover 2 sealed military weapon crates",
    "6a30b2fbd2999bc7b9bbaab8": "Survive and extract from Reserve",
    "6a30b2fbd2999bc7b9bbaab9": "Hand over 2 sealed military weapon crates to Tony",


    // Prapor's side quest 2 - Depot Rats
    "6a30b2fbd2999bc7b9bbaaf1 name": "Depot Rats",
    "6a30b2fbd2999bc7b9bbaaf1 description": "Prapor's boys are shaving ammo before it reaches the books. They call it loss, damage, bad counts, whatever makes the paperwork sleep. I call it opportunity. One of those depot rats has a skimmed ammo cache inside K Building, K4, on Reserve. You are not taking it. You are marking it. My people will collect the ammo later, and Prapor's people will keep wondering where their missing rounds went.",
    "6a30b2fbd2999bc7b9bbaaf1 note": "Tony wants you to locate and mark a skimmed ammo cache in K Building, K4, on Reserve.",
    "6a30b2fbd2999bc7b9bbaaf1 startedMessageText": "Reserve. K Building, K4. Find the skimmed ammo cache and mark it. Do not haul boxes like a mule.",
    "6a30b2fbd2999bc7b9bbaaf1 successMessageText": "Good. The stash is marked. Prapor's rats stole from him, and now I steal from the rats. I pulled a few boxes of BP from the count before my people moved the rest. Do not ask where it came from.",
    "6a30b2fbd2999bc7b9bbaaf1 failMessageText": "You missed the stash or made too much noise near it. Depot rats scatter fast.",
    "6a30b2fbd2999bc7b9bbaaf1 acceptPlayerMessage": "I'll mark the stash.",
    "6a30b2fbd2999bc7b9bbaaf1 declinePlayerMessage": "Not touching Prapor's depot rats yet.",
    "6a30b2fbd2999bc7b9bbaaf1 completePlayerMessage": "The ammo stash is marked.",
    "6a30b2fbd2999bc7b9bbaaf1 changeQuestMessageText": "Tony wants the skimmed ammo cache in K Building, K4, marked for pickup.",

    "6a30b2fbd2999bc7b9bbaaf2": "Locate the skimmed ammo cache in K Building, K4",
    "6a30b2fbd2999bc7b9bbaaf3": "Mark the skimmed ammo cache for Tony",
    "6a30b2fbd2999bc7b9bbaaf4": "Survive and extract from Reserve",

    // Therapist's side quest 1 - Test Batch
    "6a3210dbd2999bc7b9bbab06 name": "Test Batch",
    "6a3210dbd2999bc7b9bbab06 description": "Therapist throws away anything she cannot trust. That is why she sleeps better than most people in Tarkov, and why men like me still make money. Shoreline has a test batch that never made it back into clean hands: regular injectors, rejected batches, prototype stimulants, old labels, bad storage, maybe a few things Sanitar's people were smart enough not to touch. The case is in West 301 at the Health Resort. I will give you a key, but it is almost spent, so do not waste trips. Find the experimental stim case and bring it back sealed. Do not open it. Do not test anything.",
    "6a3210dbd2999bc7b9bbab06 note": "Tony wants you to recover an experimental stim case from room W301 at the Health Resort.",
    "6a3210dbd2999bc7b9bbab06 startedMessageText": "Shoreline. Health Resort west wing, room 301. Use the key, recover the experimental stim case, and bring it back sealed.",
    "6a3210dbd2999bc7b9bbab06 successMessageText": "Good. Case is sealed, labels are ugly, and half of this should probably never touch a living body. That means it will sell. Therapist would sort this by safety. I sort it by demand.",
    "6a3210dbd2999bc7b9bbab06 failMessageText": "You lost the case, opened it, wasted the key, or let Shoreline swallow you. None of that helps my business.",
    "6a3210dbd2999bc7b9bbab06 acceptPlayerMessage": "I'll recover the stim case.",
    "6a3210dbd2999bc7b9bbab06 declinePlayerMessage": "Not touching experimental medicine yet.",
    "6a3210dbd2999bc7b9bbab06 completePlayerMessage": "Here's the experimental stim case.",
    "6a3210dbd2999bc7b9bbab06 changeQuestMessageText": "Tony wants the experimental stim case recovered from West 301.",

    "6a3210dbd2999bc7b9bbab07": "Locate the experimental stim case in room W301 at the Health Resort",
    "6a3210dbd2999bc7b9bbab08": "Recover the experimental stim case",
    "6a3210dbd2999bc7b9bbab09": "Survive and extract from Shoreline",
    "6a3210dbd2999bc7b9bbab0a": "Hand over the experimental stim case to Tony",

    // Quest 8
    "6a3210dbd2999bc7b9bbab29 name": "Safe Hands",
    "6a3210dbd2999bc7b9bbab29 description": "The crates moved. The routes opened. Then someone hit one of my couriers near Interchange. He made it inside ULTRA before my people reached him, and they used Mantis as a quick triage point. Smart choice. Medical store, closed doors, enough clutter to hide behind. They pulled him out, but not everything came with them. There is a sealed trauma bag still inside Mantis. I want it back. This is not medicine for sale. This is how useful men keep breathing.",
    "6a3210dbd2999bc7b9bbab29 note": "Tony wants you to recover a sealed trauma bag from an improvised triage point inside Mantis on Interchange.",
    "6a3210dbd2999bc7b9bbab29 startedMessageText": "Interchange. Mantis, inside ULTRA. Find the triage point, recover the trauma bag, and leave alive.",
    "6a3210dbd2999bc7b9bbab29 successMessageText": "Good. Bag is back. That keeps my people alive and keeps the route moving. Safe hands are worth paying for.",
    "6a3210dbd2999bc7b9bbab29 failMessageText": "You lost the bag or let Interchange swallow you. Dead couriers are expensive. Lost supplies are worse.",
    "6a3210dbd2999bc7b9bbab29 acceptPlayerMessage": "I'll recover the trauma bag.",
    "6a3210dbd2999bc7b9bbab29 declinePlayerMessage": "Not going to Interchange for this yet.",
    "6a3210dbd2999bc7b9bbab29 completePlayerMessage": "Here's the trauma bag.",
    "6a3210dbd2999bc7b9bbab29 changeQuestMessageText": "Tony wants the Mantis triage point checked and the trauma bag recovered from Interchange.",

    "6a3210dbd2999bc7b9bbab2d": "Locate Tony's improvised triage point inside Mantis",
    "6a3210dbd2999bc7b9bbab2e": "Recover Tony's sealed trauma bag",
    "6a3210dbd2999bc7b9bbab33": "Survive and extract from Interchange",
    "6a3210dbd2999bc7b9bbab35": "Hand over Tony's sealed trauma bag",

    // Quest 9
    "6a39bb7182d8dd83f87b1f6b name": "Broken Radios",
    "6a39bb7182d8dd83f87b1f6b description": "The bags moved, the crates moved, and now the coast is listening. Someone has a contact route on Lighthouse, and they are using satellite equipment to watch movement I would rather keep quiet. I do not need them dead. Dead men get replaced. I need them blind. Take these Signal Jammers. Place one near the satellite equipment at the tennis court and another at the first helipad. Once their equipment starts screaming, my people can move without every clean-dollar errand boy hearing about it.",
    "6a39bb7182d8dd83f87b1f6b note": "Tony wants you to place Signal Jammers near satellite communication equipment on Lighthouse.",
    "6a39bb7182d8dd83f87b1f6b startedMessageText": "Lighthouse. Tennis court satellites first, then the first helipad. Plant the jammers and leave alive.",
    "6a39bb7182d8dd83f87b1f6b successMessageText": "Good. Their radios will not be clean for a while. When the coast goes quiet, my people move.",
    "6a39bb7182d8dd83f87b1f6b failMessageText": "You lost the jammers, missed the equipment, or let Lighthouse chew you up. That does not blind anyone.",
    "6a39bb7182d8dd83f87b1f6b acceptPlayerMessage": "I'll plant the jammers.",
    "6a39bb7182d8dd83f87b1f6b declinePlayerMessage": "Not touching Lighthouse comms yet.",
    "6a39bb7182d8dd83f87b1f6b completePlayerMessage": "The satellite equipment is jammed.",
    "6a39bb7182d8dd83f87b1f6b changeQuestMessageText": "Tony wants Signal Jammers placed near Lighthouse satellite equipment.",

    "6a39fcff82d8dd83f87b1fa7": "Place the first Signal Jammer near the satellite equipment at the tennis court",
    "6a39bb7182d8dd83f87b1f6d": "Place the second Signal Jammer near the satellite equipment at the first helipad",
    "6a39bb7182d8dd83f87b1f71": "Survive and extract from Lighthouse",

    //Quest 10
    "6a39bce282d8dd83f87b1f84 name": "Paper Shields",
    "6a39bce282d8dd83f87b1f84 description": "Bullets open doors, but paper keeps them open. My people are moving more now, and moving men need names, manifests, stamps, and lies that look official under bad light. There is a packet of forged route documents hidden in the guard office of two-story Dorms on Customs. Bring it to me sealed. If you read it, you will only learn names that are bad for your health.",
    "6a39bce282d8dd83f87b1f84 note": "Tony wants you to recover forged route documents from the guard office in two-story Dorms.",
    "6a39bce282d8dd83f87b1f84 startedMessageText": "Customs. Two-story Dorms. Guard office. Find the forged route documents and leave alive.",
    "6a39bce282d8dd83f87b1f84 successMessageText": "Good. Paper shields, my friend. A stamp in the right place can stop more bullets than armor.",
    "6a39bce282d8dd83f87b1f84 failMessageText": "You lost the papers or let Dorms eat you. Without documents, every route looks like a crime scene.",
    "6a39bce282d8dd83f87b1f84 acceptPlayerMessage": "I'll recover the documents.",
    "6a39bce282d8dd83f87b1f84 declinePlayerMessage": "Not going into Dorms for papers yet.",
    "6a39bce282d8dd83f87b1f84 completePlayerMessage": "Here are the forged route documents.",
    "6a39bce282d8dd83f87b1f84 changeQuestMessageText": "Tony wants the forged route documents recovered from two-story Dorms.",

    "6a39bce282d8dd83f87b1f88": "Locate the guard office in two-story Dorms",
    "6a39bce282d8dd83f87b1f89": "Recover the forged route documents",
    "6a39bce282d8dd83f87b1f8e": "Survive and extract from Customs",
    "6a39bce282d8dd83f87b1f90": "Hand over the forged route documents",

    // Quest 11
    "6a39fcff82d8dd83f87b1fa9 name": "Clean Run",
    "6a39fcff82d8dd83f87b1fa9 description": "The radios are blind and the papers are clean enough to pass under bad light. Now we test the route with cargo that matters. I am giving you three sealed packages. Customs, Interchange, Streets. One package for each cache. Do not open them, do not lose them, and do not ask what they are worth. If one disappears, you replace the value yourself before you finish the job.",
    "6a39fcff82d8dd83f87b1fa9 note": "Tony wants you to stash three sealed cargo packages across Customs, Interchange, and Streets.",
    "6a39fcff82d8dd83f87b1fa9 startedMessageText": "Three packages. Train car near Fortress, Goshan flatbed, LexOs container. Keep the run clean.",
    "6a39fcff82d8dd83f87b1fa9 successMessageText": "Good. Customs opened, Interchange moved, Streets received. That is a clean run. Now I know the route works.",
    "6a39fcff82d8dd83f87b1fa9 failMessageText": "Lost cargo, broken route, dead courier. None of that is clean.",
    "6a39fcff82d8dd83f87b1fa9 acceptPlayerMessage": "I'll move the packages.",
    "6a39fcff82d8dd83f87b1fa9 declinePlayerMessage": "Not running cargo yet.",
    "6a39fcff82d8dd83f87b1fa9 completePlayerMessage": "The packages are stashed.",
    "6a39fcff82d8dd83f87b1fa9 changeQuestMessageText": "Tony wants three sealed cargo packages stashed across the route.",

    "6a39fcff82d8dd83f87b1faa": "Stash the first sealed cargo package in the train car near Fortress",
    "6a39fcff82d8dd83f87b1fab": "Stash the second sealed cargo package in the flatbed truck at the back of Goshan",
    "6a39fcff82d8dd83f87b1fad": "Stash the third sealed cargo package in the closed container behind LexOs",
    "6a39fcff82d8dd83f87b1fb1": "Survive and extract",


    // Prapor's side quest 3 - Red Caliber
    "6a3cab9782d8dd83f87b1fd1 name": "Red Caliber",
    "6a3cab9782d8dd83f87b1fd1 description": "Prapor's boys keep losing rifles, ammo, and men in the trees. I do not waste good boxes on someone who sprays at shadows and dies with a warm barrel. Woods is where old BEARs learned patience. Take a Russian-service weapon, put down five PMCs, and leave alive. Do that, and I will know the better ammo is not being wasted.",
    "6a3cab9782d8dd83f87b1fd1 note": "Tony wants you to prove yourself on Woods with Russian-service weapons.",
    "6a3cab9782d8dd83f87b1fd1 startedMessageText": "Woods. Russian steel. Five PMCs. Leave alive.",
    "6a3cab9782d8dd83f87b1fd1 successMessageText": "Good. Red caliber still does honest work in the right hands. I will open a few better boxes for you, but do not mistake access for charity.",
    "6a3cab9782d8dd83f87b1fd1 failMessageText": "Dead men do not get better ammo. Try again when you can keep your rifle and your pulse steady.",
    "6a3cab9782d8dd83f87b1fd1 acceptPlayerMessage": "I'll prove it with Russian steel.",
    "6a3cab9782d8dd83f87b1fd1 declinePlayerMessage": "Not going to Woods for this yet.",
    "6a3cab9782d8dd83f87b1fd1 completePlayerMessage": "Five PMCs down. I made it out.",
    "6a3cab9782d8dd83f87b1fd1 changeQuestMessageText": "Tony wants proof you can fight with Russian-service weapons on Woods.",

    "6a3cab9782d8dd83f87b1fd5": "Eliminate 5 PMCs on Woods with Russian-service weapons without dying",
    "6a3cab9782d8dd83f87b1fd9": "Survive and extract from Woods",

    // Therapist's side quest 2 - Street Clinic
    "6a3fd74f82d8dd83f87b1ff0 name": "Street Clinic",
    "6a3fd74f82d8dd83f87b1ff0 description": "The route into Streets works. Good. Now I need people on that side who can keep my couriers breathing. There is an old pharmacy on Primorsky Ave, across from LexOs. The front looks dead, but the back room may still be used by a street doctor who treats men who cannot walk into Therapist's place. Find the clinic, confirm the doctor is still operating, and leave alive. If he is still there, I can start moving field kits through him.",
    "6a3fd74f82d8dd83f87b1ff0 note": "Tony wants you to locate a back-alley clinic contact inside an old pharmacy on Primorsky Ave.",
    "6a3fd74f82d8dd83f87b1ff0 startedMessageText": "Streets. Primorsky Ave, across from LexOs. Find the old pharmacy, check the back room, and leave alive.",
    "6a3fd74f82d8dd83f87b1ff0 successMessageText": "Good. The clinic still breathes. The doctor is dirty, quiet, and useful. That means my people can get patched without begging Therapist, and you can get field kits through me.",
    "6a3fd74f82d8dd83f87b1ff0 failMessageText": "You missed the clinic or let Streets swallow you. A doctor who cannot be found is the same as no doctor at all.",
    "6a3fd74f82d8dd83f87b1ff0 acceptPlayerMessage": "I'll find the clinic.",
    "6a3fd74f82d8dd83f87b1ff0 declinePlayerMessage": "Not going to Streets for a back-alley doctor yet.",
    "6a3fd74f82d8dd83f87b1ff0 completePlayerMessage": "The clinic is still operating.",
    "6a3fd74f82d8dd83f87b1ff0 changeQuestMessageText": "Tony wants the old pharmacy clinic on Primorsky Ave checked.",

    "6a3fd74f82d8dd83f87b1ff4": "Locate the back-alley clinic inside the old pharmacy on Primorsky Ave",
    "6a3fd74f82d8dd83f87b1ff8": "Confirm the street doctor is still operating",
    "6a3fd74f82d8dd83f87b1ffd": "Survive and extract from Streets",

    // Ragman's side quest 1 - Used But Usable
    "6a413ec882d8dd83f87b2053 name": "Used But Usable",
    "6a413ec882d8dd83f87b2053 description": "Ragman sells clean fabric and straight stitching. I need something cheaper. KIBA has seen enough panic, looting, and bad decisions to leave useful scraps behind. First, get inside after the power comes on. Then bring me armor plates and tactical rigs. Torn straps can be sewn. Plates can be re-housed. Ugly gear is still gear if the right hands touch it.",
    "6a413ec882d8dd83f87b2053 note": "Tony wants you to get into KIBA on Interchange, then bring him armor plates and tactical rigs for cheap refurbished gear.",
    "6a413ec882d8dd83f87b2053 startedMessageText": "Interchange. Power first, KIBA second. After that, bring me plates and rigs.",
    "6a413ec882d8dd83f87b2053 successMessageText": "Good. Used, burned, cracked, torn \u2014 does not matter. My people can make it usable again, and you get cheaper gear because of it.",
    "6a413ec882d8dd83f87b2053 failMessageText": "You came back with nothing useful. KIBA is dangerous, but empty hands are worse.",
    "6a413ec882d8dd83f87b2053 acceptPlayerMessage": "I'll see what KIBA has left.",
    "6a413ec882d8dd83f87b2053 declinePlayerMessage": "Not going into KIBA for salvage yet.",
    "6a413ec882d8dd83f87b2053 completePlayerMessage": "Here are the plates and rigs.",
    "6a413ec882d8dd83f87b2053 changeQuestMessageText": "Tony wants KIBA checked and salvage materials handed over.",

    "6a413ec882d8dd83f87b2057": "Locate KIBA Arms inside ULTRA",
    "6a413ec882d8dd83f87b205b": "Enter KIBA Arms after power has been restored",
    "6a413ec882d8dd83f87b205d": "Hand over any 5 armor plates",
    "6a413ec882d8dd83f87b205f": "Hand over any 3 tactical rigs",
    "6a41407d82d8dd83f87b2064": "Survive and extract from Interchange",

    // Quest 12
    "6a415fe582d8dd83f87b209b name": "Cold Freight",
    "6a415fe582d8dd83f87b209b description": "The clean route worked. Now we look for heavier freight. Interchange has locked containers tied to old access cards, 21WS and 11SR. People think a locked door means ownership. It does not. It means someone was afraid of losing what was inside. Take these markers, tag both containers, and leave. My crew will handle the cold work after you are gone.",
    "6a415fe582d8dd83f87b209b note": "Tony wants you to mark the locked 21WS and 11SR shipment containers on Interchange.",
    "6a415fe582d8dd83f87b209b startedMessageText": "Interchange. Two locked containers. 21WS and 11SR. Mark them and leave alive.",
    "6a415fe582d8dd83f87b209b successMessageText": "Good. The freight is tagged, and my people know where to cut. Locked doors only slow honest men.",
    "6a415fe582d8dd83f87b209b failMessageText": "The containers are still unmarked. Cold freight does not move itself.",
    "6a415fe582d8dd83f87b209b acceptPlayerMessage": "I'll mark the containers.",
    "6a415fe582d8dd83f87b209b declinePlayerMessage": "Not touching locked freight yet.",
    "6a415fe582d8dd83f87b209b completePlayerMessage": "The containers are marked.",
    "6a415fe582d8dd83f87b209b changeQuestMessageText": "Tony wants the locked Interchange freight containers marked for his crew.",

    "6a415fe582d8dd83f87b209c": "Mark the locked 21WS shipment container for Tony's crew",
    "6a415fe582d8dd83f87b209d": "Mark the locked 11SR shipment container for Tony's crew",
    "6a415fe582d8dd83f87b20a1": "Survive and extract from Interchange",

    // Quest 13
    "6a417a6c82d8dd83f87b20d4 name": "Dead Drop Rules",
    "6a417a6c82d8dd83f87b20d4 description": "A dead drop is not a trash can. You do not empty it, you do not stand over it, and you do not come back twice if someone is watching. I need to know you understand that before I put better goods in your hands. Woods has two old drops still worth using. Check the first drop, recover the coded dog tag, move it to the second drop, and leave alive. One raid. No excuses.",
    "6a417a6c82d8dd83f87b20d4 note": "Tony wants you to move a coded dead-drop tag between two Woods dead drops and extract alive.",
    "6a417a6c82d8dd83f87b20d4 startedMessageText": "Woods. First drop, coded tag, second drop. Move clean and leave alive.",
    "6a417a6c82d8dd83f87b20d4 successMessageText": "Good. You followed the rules. The tag moved, the route stayed quiet, and nobody had to say your name.",
    "6a417a6c82d8dd83f87b20d4 failMessageText": "You lost the tag, missed the drop, or died walking the route. That is not how couriers survive.",
    "6a417a6c82d8dd83f87b20d4 acceptPlayerMessage": "I'll move the tag.",
    "6a417a6c82d8dd83f87b20d4 declinePlayerMessage": "Not running dead drops yet.",
    "6a417a6c82d8dd83f87b20d4 completePlayerMessage": "The tag was moved.",
    "6a417a6c82d8dd83f87b20d4 changeQuestMessageText": "Tony wants the coded dead-drop tag moved between two Woods dead drops.",

    "6a417a6c82d8dd83f87b20d8": "Locate the first dead drop on Woods",
    "6a417a6c82d8dd83f87b20da": "Recover Tony's coded dead-drop tag",
    "6a417a6c82d8dd83f87b20dc": "Stash Tony's coded dead-drop tag at the second dead drop",
    "6a417a6c82d8dd83f87b20e1": "Survive and extract from Woods",

    // Quest 14
    "6a41d30482d8dd83f87b20fa name": "Worn Down",
    "6a41d30482d8dd83f87b20fa description": "Clean weapons are for men with supply lines. Out here, sometimes you get a tired barrel, weak springs, bad feed lips, and a little oil holding the whole thing together. Factory is perfect for this lesson. No long walks. No soft angles. No time to blame the gun. Take a worn-down weapon into the plant and put PMCs down with it. If it jams, clear it. If it kicks wrong, hold it tighter. If it fails, make it work anyway.",
    "6a41d30482d8dd83f87b20fa startedMessageText": "Factory. Worn-down weapon. PMC bodies. Bring me proof that bad steel still works in steady hands.",
    "6a41d30482d8dd83f87b20fa successMessageText": "Good. Now you understand something most people learn too late. A clean weapon is a comfort. A working weapon is a decision. You kept broken steel alive long enough to do the job, and that means I can trust you with gear that has already seen bad days.",
    "6a41d30482d8dd83f87b20fa failMessageText": "The weapon was rough. Factory was worse. That was the point. Bring me results, not excuses.",
    "6a41d30482d8dd83f87b20fa acceptPlayerMessage": "I'll make it work.",
    "6a41d30482d8dd83f87b20fa completePlayerMessage": "The weapon held long enough.",
    "6a41d30482d8dd83f87b20fa declinePlayerMessage": "Not testing broken steel yet.",
    "6a41d30482d8dd83f87b20fa changeQuestMessageText": "Tony wants PMC kills on Factory with a worn-down weapon.",
    "6a41d30482d8dd83f87b20fa note": "Kill PMCs on Factory while using a damaged or low-durability weapon, then survive the raid.",

    "6a41d30482d8dd83f87b20ff": "Kill PMCs on Factory while using a worn-down weapon",
    "6a41d30482d8dd83f87b210a": "Survive and extract from Factory",

    // Quest 15
    "6a4341ac38a6d33bffe9829e name": "Foreign Parts",
    "6a4341ac38a6d33bffe9829e description": "The coast is full of clean rifles, clean plates, and clean lies. Rogues move Western parts through Lighthouse like the beach belongs to them. It does not. I want material and I want proof. Bring me Western weapons, bring me Rogue kit, mark the beach shipment, and pull the shipment records from the lower-floor bunk room in Warehouse 3. My boys will handle the heavy cargo after you leave.",
    "6a4341ac38a6d33bffe9829e note": "Tony wants Western weapons, Rogue tactical gear, a beach shipment marked, and shipment evidence recovered from Warehouse 3.",
    "6a4341ac38a6d33bffe9829e startedMessageText": "Lighthouse. Strip the foreign gear, mark the beach shipment, and pull the paperwork from Warehouse 3.",
    "6a4341ac38a6d33bffe9829e successMessageText": "Good. Foreign parts, foreign lies, same old greed. Now I know what they are moving, where it touches the beach, and what can be pulled apart for my own shelves.",
    "6a4341ac38a6d33bffe9829e failMessageText": "You missed the shipment, lost the evidence, or came back without material. The coast does not get quieter because you tried.",
    "6a4341ac38a6d33bffe9829e acceptPlayerMessage": "I'll hit the Rogue supply line.",
    "6a4341ac38a6d33bffe9829e declinePlayerMessage": "Not touching Rogue freight yet.",
    "6a4341ac38a6d33bffe9829e completePlayerMessage": "I brought the gear and the evidence.",
    "6a4341ac38a6d33bffe9829e changeQuestMessageText": "Tony wants Rogue supply gear and shipment evidence from Lighthouse.",

    "6a4341ac38a6d33bffe9829f": "Find in raid and hand over 2 Western weapons",
    "6a4341ac38a6d33bffe982a0": "Find in raid and hand over 3 pieces of Rogue tactical gear",
    "6a4341ac38a6d33bffe982a1": "Mark the Rogue shipment on the beach for Tony's crew",
    "6a4341ac38a6d33bffe982a2": "Recover the Rogue shipment evidence from the Warehouse 3 lower floor bunk room",
    "6a4341ac38a6d33bffe982a6": "Survive and extract from Lighthouse",
    "6a4341ac38a6d33bffe982a7": "Hand over the shipment evidence",

    // Side quest - Parapor's side quest 4 - Bunker Tax
    "6a480d82fb1eff152bd64946 name": "Bunker Tax",
    "6a480d82fb1eff152bd64946 description": "Reserve has rats under the concrete. Not the hungry kind — the kind with rifles, tools, and boxes of parts they think nobody is counting. They have been stripping military stock and moving repair goods through my route without paying their cut. I like business. I do not like freeloaders. Go underground, find the bunker command center, and put down the PMCs working that space. Six bodies should remind the rest who owns the lane.",
    "6a480d82fb1eff152bd64946 note": "Tony wants you to locate the bunker command center, kill PMCs underground, and extract from Reserve.",
    "6a480d82fb1eff152bd64946 startedMessageText": "Reserve. Underground. Find the command center and collect bunker tax from the PMCs working the tunnels.",
    "6a480d82fb1eff152bd64946 successMessageText": "Good. The bunker hears Tony now. Parts, tools, repairs — all of it moves cleaner when the freeloaders remember there is a price for breathing in my lane.",
    "6a480d82fb1eff152bd64946 failMessageText": "You found concrete and excuses, not tax. Go back when you can make the bunker listen.",
    "6a480d82fb1eff152bd64946 acceptPlayerMessage": "I'll collect the tax.",
    "6a480d82fb1eff152bd64946 declinePlayerMessage": "Not going under Reserve yet.",
    "6a480d82fb1eff152bd64946 completePlayerMessage": "The bunker was taxed.",
    "6a480d82fb1eff152bd64946 changeQuestMessageText": "Tony wants PMCs eliminated underground in the Reserve bunker.",
    "6a480d82fb1eff152bd6494a": "Locate the bunker command center under Reserve",
    "6a480d82fb1eff152bd6494e": "Eliminate 6 PMCs underground in the Reserve bunker",
    "6a480d82fb1eff152bd64953": "Survive and extract from Reserve",

    // Side quest - Therapist's side quest 3 - Cold Chain
    "6a4920e2fb1eff152bd64982 name": "Cold Chain",
    "6a4920e2fb1eff152bd64982 description": "The doctor is real. Good. A doctor without stock is just a man with dirty hands and good intentions. Interchange still has pharmacy stock sitting behind dead counters and locked supply shelves. IDEA side, near the front. There should be a sealed cold-chain case there. I do not want loose pills, open bottles, or half-rotten garbage. Bring me the sealed case and leave alive. If the cold packs are dead, someone desperate will still call it medicine.",
    "6a4920e2fb1eff152bd64982 note": "Tony wants you to recover a sealed cold-chain medical case from the IDEA-side pharmacy on Interchange.",
    "6a4920e2fb1eff152bd64982 startedMessageText": "Interchange. IDEA side pharmacy, near the front. Find the cold-chain case and leave alive.",
    "6a4920e2fb1eff152bd64982 successMessageText": "Good. The case is sealed, and that means my street doctor can stop working from empty shelves. Bigger kits, colder stock, and a few special mixes will start moving through the clinic now. Therapist would ask where it came from. I ask whether it still works.",
    "6a4920e2fb1eff152bd64982 failMessageText": "You lost the case, broke the seals, or let Interchange swallow you. A clinic without stock is just a room with bad lighting.",
    "6a4920e2fb1eff152bd64982 acceptPlayerMessage": "I'll recover the cold-chain case.",
    "6a4920e2fb1eff152bd64982 declinePlayerMessage": "Not going to Interchange for clinic stock yet.",
    "6a4920e2fb1eff152bd64982 completePlayerMessage": "Here's the cold-chain case.",
    "6a4920e2fb1eff152bd64982 changeQuestMessageText": "Tony wants the cold-chain medical case recovered from the IDEA-side pharmacy.",

    "6a4920e2fb1eff152bd64986": "Locate the IDEA-side pharmacy on Interchange",
    "6a4920e2fb1eff152bd64987": "Recover the cold-chain medical case",
    "6a4920e2fb1eff152bd6498d": "Survive and extract from Interchange",
    "6a4920e2fb1eff152bd6498f": "Hand over the cold-chain medical case",

    // Side quest - Ragman's side quest 2 - Street Colors
    "6a494a6bfb1eff152bd649d2 name": "Street Colors",
    "6a494a6bfb1eff152bd649d2 description": "Streets has colors. Not pretty ones \u2014 working colors. Masks, rigs, jackets, little signs men use so their friends know who not to shoot. I want my color remembered. Put on the Death Shadow mask and work the street. Ten PMCs. Let them see the face before the shooting starts.",
    "6a494a6bfb1eff152bd649d2 note": "Tony wants you to eliminate PMCs on Streets while wearing a Death Shadow mask.",
    "6a494a6bfb1eff152bd649d2 startedMessageText": "Streets. Death Shadow mask. Ten PMCs. Make the face mean something.",
    "6a494a6bfb1eff152bd649d2 successMessageText": "Good. Now that mask is not just cloth and paint. It is a warning. Ragman will understand the value of that better than most.",
    "6a494a6bfb1eff152bd649d2 failMessageText": "You wore the face and did not make it matter. Streets does not remember almost.",
    "6a494a6bfb1eff152bd649d2 acceptPlayerMessage": "I'll wear the mask.",
    "6a494a6bfb1eff152bd649d2 declinePlayerMessage": "Not wearing Tony's colors yet.",
    "6a494a6bfb1eff152bd649d2 completePlayerMessage": "The street saw the mask.",
    "6a494a6bfb1eff152bd649d2 changeQuestMessageText": "Tony wants PMC kills on Streets while wearing a Death Shadow mask.",

    "6a494a6bfb1eff152bd649d6": "Eliminate 10 PMCs on Streets while wearing a Death Shadow mask",
    "6a494a6bfb1eff152bd649da": "Survive and extract from Streets"

    // Side quest - Skier's side quest 1 - Pocket Work

}